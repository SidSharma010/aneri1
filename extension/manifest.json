{
  "manifest_version": 3,
  "name": "LinkedIn VA Outreach Helper",
  "description": "A consent-first LinkedIn helper for organizing VA outreach, drafting invite notes, and tracking follow-ups.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/in/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}